# ═══════════════════════════════════════════════════════════
# local.properties.example — Copy to local.properties
# ψ: Configure SDK/NDK paths for your local environment
# ═══════════════════════════════════════════════════════════

# Android SDK location (required)
sdk.dir=/path/to/Android/Sdk
# Example Linux:   sdk.dir=/home/user/Android/Sdk
# Example macOS:   sdk.dir=/Users/user/Library/Android/sdk
# Example Windows: sdk.dir=C\:\\Users\\user\\AppData\\Local\\Android\\sdk

# Android NDK location (optional — Gradle will use ndkVersion from gradle.properties)
# Uncomment and set if you need to pin a specific NDK path
# ndk.dir=/path/to/Android/Sdk/ndk/27.2.12479018

# CMake version (must match gradle.properties CMAKE_VERSION)
# cmake.dir=/path/to/cmake/3.22.1

# ── JNI Build flags (optional overrides) ────────────────────
# NATIVE_MCPU=cortex-a78     # Override mcpu for ARM64 JNI build
# RMR_ENABLE_POLICY_MODULE=ON
# RMR_ENABLE_BITRAF_MODULE=ON
