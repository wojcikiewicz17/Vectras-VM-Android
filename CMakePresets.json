{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 1
  },
  "configurePresets": [
    {
      "name": "host-ninja",
      "displayName": "Host Linux Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-cmake-host",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RMR_JNI_BUILD": "ON",
        "RMR_ENABLE_POLICY_MODULE": "ON"
      }
    },
    {
      "name": "android-base",
      "displayName": "Android base toolchain",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-cmake-android-${presetName}",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "CMAKE_SYSTEM_VERSION": "24",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK_ROOT}",
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
        "ANDROID_STL": "none",
        "RMR_JNI_BUILD": "ON",
        "RMR_ENABLE_POLICY_MODULE": "ON"
      }
    },
    {
      "name": "android-armv7",
      "inherits": "android-base",
      "displayName": "Android ARM32 v7",
      "cacheVariables": {
        "CMAKE_ANDROID_ARCH_ABI": "armeabi-v7a",
        "CMAKE_ANDROID_ARM_MODE": "ON",
        "CMAKE_ANDROID_ARM_NEON": "ON"
      }
    },
    {
      "name": "android-arm64-v8",
      "inherits": "android-base",
      "displayName": "Android ARM64 v8",
      "cacheVariables": {
        "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-host",
      "configurePreset": "host-ninja"
    },
    {
      "name": "build-android-armv7",
      "configurePreset": "android-armv7",
      "targets": [
        "verify_contracts"
      ]
    },
    {
      "name": "build-android-arm64-v8",
      "configurePreset": "android-arm64-v8",
      "targets": [
        "verify_contracts"
      ]
    }
  ]
}
