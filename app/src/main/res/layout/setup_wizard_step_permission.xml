<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/ln_allow_permission"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:orientation="vertical"
            android:padding="@dimen/setup_wizard_screen_padding">

            <ImageView
                style="@style/Widget.Vectras.SetupWizard.HeaderIcon"
                android:src="@drawable/folder_100px"
                android:contentDescription="@null"
                android:importantForAccessibility="no" />

            <TextView
                style="@style/TextAppearance.Vectras.SetupWizard.Title"
                android:text="@string/allow_access_to_storage" />

            <TextView
                style="@style/TextAppearance.Vectras.SetupWizard.Body"
                android:text="@string/you_need_to_allow_access_to_the_storage_to_continue" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom|end">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_allow_permission"
                    style="@style/Widget.Vectras.SetupWizard.Button.Primary"
                    android:text="@string/allow" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</merge>
