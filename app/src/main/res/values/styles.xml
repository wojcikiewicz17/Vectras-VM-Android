<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CenteredDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog.Centered" />

    <style name="App.MaterialSwitch" parent="@style/Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbIcon">@drawable/switch_thumb_icon</item>
    </style>

    <style name="App.CollapsingToolbarLarge" parent="Widget.Material3.CollapsingToolbar.Large">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?attr/collapsingToolbarLayoutLargeSize</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="layout_scrollFlags">scroll|exitUntilCollapsed</item>
        <item name="android:background">?attr/colorSurfaceContainerLow</item>
        <item name="contentScrim">?attr/colorSurfaceContainerLow</item>
        <item name="statusBarScrim">?attr/colorSurfaceContainerLow</item>
        <item name="collapsedTitleTextAppearance">@style/TextAppearance.Material3.TitleMedium</item>
        <item name="expandedTitleTextAppearance">@style/TextAppearance.Material3.DisplaySmall</item>
    </style>

    <style name="App.CollapsingMaterialToolbar" parent="Widget.Material3.Toolbar">
        <item name="theme">@style/ThemeOverlay.AppCompat.ActionBar</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?attr/actionBarSize</item>
        <item name="android:elevation">0dp</item>
        <item name="layout_collapseMode">pin</item>
        <item name="navigationIcon">@drawable/arrow_back_rounded_24px</item>
    </style>


    <!-- Compat aliases when expressive Material3 styles are unavailable in current artifact set -->
    <style name="Widget.Material3Expressive.Button" parent="Widget.Material3.Button" />
    <style name="Widget.Material3Expressive.Button.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton" />
    <style name="Widget.Material3Expressive.Button.IconButton" parent="Widget.Material3.Button" />
    <style name="Widget.Material3Expressive.Button.TonalButton" parent="Widget.Material3.Button.TonalButton" />
    <style name="ThemeOverlay.Material3Expressive.AppBarWithSearch" parent="ThemeOverlay.Material3.ActionBar" />
    <style name="MaterialAlertDialog.Material3Expressive.Title.Text" parent="TextAppearance.Material3.TitleLarge" />


    <style name="Widget.Vectras.IconOnlyControlButton" parent="@style/Widget.AppCompat.ImageButton">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

</resources>