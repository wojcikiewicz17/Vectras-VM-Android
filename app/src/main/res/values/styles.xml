<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CenteredDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog.Centered" />

    <style name="App.MaterialSwitch" parent="@style/Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbIcon">@drawable/switch_thumb_icon</item>
    </style>

    <style name="App.CollapsingToolbarLarge" parent="Widget.Material3.CollapsingToolbar.Large">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?attr/collapsingToolbarLayoutLargeSize</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="layout_scrollFlags">scroll|exitUntilCollapsed</item>
        <item name="android:background">?attr/colorSurfaceContainerLow</item>
        <item name="contentScrim">?attr/colorSurfaceContainerLow</item>
        <item name="statusBarScrim">?attr/colorSurfaceContainerLow</item>
        <item name="collapsedTitleTextAppearance">@style/TextAppearance.Material3.TitleMedium</item>
        <item name="expandedTitleTextAppearance">@style/TextAppearance.Material3.DisplaySmall</item>
    </style>

    <style name="App.CollapsingMaterialToolbar" parent="Widget.Material3.Toolbar">
        <item name="theme">@style/ThemeOverlay.AppCompat.ActionBar</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?attr/actionBarSize</item>
        <item name="android:elevation">0dp</item>
        <item name="layout_collapseMode">pin</item>
        <item name="navigationIcon">@drawable/arrow_back_rounded_24px</item>
    </style>

    <style name="Widget.Material3Expressive.Button" parent="Widget.Material3.Button" />
    <style name="Widget.Material3Expressive.Button.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton" />
    <style name="Widget.Material3Expressive.Button.IconButton" parent="Widget.Material3.Button" />
    <style name="Widget.Material3Expressive.Button.TonalButton" parent="Widget.Material3.Button.TonalButton" />
    <style name="ThemeOverlay.Material3Expressive.AppBarWithSearch" parent="ThemeOverlay.Material3.ActionBar" />
    <style name="MaterialAlertDialog.Material3Expressive.Title.Text" parent="TextAppearance.Material3.TitleLarge" />

    <style name="Widget.Vectras.IconOnlyControlButton" parent="@style/Widget.AppCompat.ImageButton">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="TextAppearance.Vectras.SetupWizard.Title" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">@dimen/setup_wizard_title_text_size</item>
        <item name="android:layout_marginTop">@dimen/setup_wizard_content_padding_small</item>
    </style>

    <style name="TextAppearance.Vectras.SetupWizard.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Vectras.SetupWizard.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Vectras.SetupWizard.OptionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/setup_wizard_option_title_text_size</item>
    </style>

    <style name="TextAppearance.Vectras.SetupWizard.OptionBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/setup_wizard_option_body_text_size</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Vectras.SetupWizard.StepStatus" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.Vectras.SetupWizard.HeaderIcon" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="Widget.Vectras.SetupWizard.ProgressIndicator" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackColor">?attr/colorSurfaceContainerHigh</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
    </style>

    <style name="Widget.Vectras.SetupWizard.OptionCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerHigh</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Material3.MediumComponent</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:padding">@dimen/setup_wizard_screen_padding</item>
        <item name="rippleColor">?attr/colorPrimaryContainer</item>
    </style>

    <style name="Widget.Vectras.SetupWizard.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Material3.MediumComponent</item>
    </style>

    <style name="Widget.Vectras.SetupWizard.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minWidth">96dp</item>
    </style>

    <style name="Widget.Vectras.SetupWizard.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton" />

    <style name="Widget.Vectras.SetupWizard.Button.Tertiary" parent="Widget.Material3.Button.TextButton" />

    <style name="Widget.Vectras.SetupWizard.StepBadge" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:layout_width">@dimen/setup_wizard_step_badge_size</item>
        <item name="android:layout_height">@dimen/setup_wizard_step_badge_size</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:background">@drawable/bg_setup_wizard_step_badge_pending</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
